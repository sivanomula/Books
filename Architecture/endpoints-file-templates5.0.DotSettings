	[ApiVersion("1.0")]&#xD;
    [Route(RouteTemplate.Get)]&#xD;
    public class Get : BaseAsyncEndpoint.WithRequest&lt;GetRequest&gt;.WithResponse&lt;GetResponse&gt;&#xD;
    {        &#xD;
        [SwaggerOperation(&#xD;
			Summary = GetSwaggerMetadata.Summary,&#xD;
			Description = GetSwaggerMetadata.Description,&#xD;
            OperationId = nameof(Get),&#xD;
            Tags = new[] { SharedSwaggerMetadata.Tag }&#xD;
        )]&#xD;
        [ProducesResponseType(typeof(GetResponse), StatusCodes.Status200OK)]&#xD;
        [ProducesResponseType(StatusCodes.Status400BadRequest)]&#xD;
        [ProducesResponseType(StatusCodes.Status404NotFound)]&#xD;
        [HttpGet]&#xD;
        public override async Task&lt;ActionResult&lt;GetResponse&gt;&gt; HandleAsync(&#xD;
            [FromQuery] GetRequest request,&#xD;
            CancellationToken cancellationToken = default)&#xD;
        {&#xD;
            return await Task.FromResult(StatusCode(StatusCodes.Status501NotImplemented));&#xD;
        }&#xD;
	}&#xD;
}</s:String>
